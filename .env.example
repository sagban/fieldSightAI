# Required: Gemini API key (for Agent 2 / File Search; get one at https://aistudio.google.com/apikey)
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"

# Vertex AI (for Gemini Live API on backend). Use Application Default Credentials:
#   gcloud auth application-default login
# Or set GOOGLE_APPLICATION_CREDENTIALS to a service account key path.
GOOGLE_CLOUD_PROJECT="your-gcp-project-id"
GOOGLE_CLOUD_LOCATION="us-central1"

# Optional: File Search store name (created by seed_stores.py)
FILE_SEARCH_STORE_NAME="fieldsight-standards"

# Optional: Live session timeout in seconds
# LIVE_SESSION_TIMEOUT_SECONDS=180
# Optional: Live model name
# LIVE_MODEL=gemini-2.5-flash-preview-05-20
